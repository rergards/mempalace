+def test_interval_due_when_old_enough():
+    config = VersionCheckConfig(enabled=True, source="state", interval_hours=168)
+    now = time.time()
+    state = VersionCheckState(last_check_ts=now - 169 * 3600)
+    assert _interval_due(state, config, now)
