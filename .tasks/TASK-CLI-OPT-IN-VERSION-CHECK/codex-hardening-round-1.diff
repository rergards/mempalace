+def test_interval_not_due_when_recent():
+    config = VersionCheckConfig(enabled=True, source="state", interval_hours=168)
+    now = time.time()
+    state = VersionCheckState(last_check_ts=now - 10)
+    assert not _interval_due(state, config, now)
